{
  "name": "eagles-ai-platform",
  "version": "0.1.0",
  "private": true,
  "description": "EAGLES Advanced — token tracking, vector memory, and drift detection MCPs",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:ordered": "pnpm run build:shared && pnpm run build:data && pnpm run build:registry && pnpm run build:mcps && pnpm run build:bench",
    "build:registry": "pnpm --filter @eagles-ai-platform/tool-registry run build",
    "build:shared": "pnpm --filter @eagles-ai-platform/shared-utils run build",
    "build:data": "pnpm --filter @eagles-ai-platform/data-layer run build",
    "build:verification": "pnpm --filter @eagles-ai-platform/verification-mcp run build",
    "build:orchestrator": "pnpm --filter @eagles-ai-platform/orchestrator-mcp run build",
    "build:mcps": "pnpm --filter @eagles-ai-platform/token-tracker-mcp --filter @eagles-ai-platform/vector-memory-mcp --filter @eagles-ai-platform/drift-detector-mcp --filter @eagles-ai-platform/provider-router-mcp --filter @eagles-ai-platform/verification-mcp --filter @eagles-ai-platform/orchestrator-mcp run build",
    "build:provider-router": "pnpm --filter @eagles-ai-platform/provider-router-mcp run build",
    "build:bench": "pnpm --filter @eagles-ai-platform/benchmark run build",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "setup": "bash scripts/setup.sh",
    "benchmark": "pnpm --filter @eagles-ai-platform/benchmark run start",
    "smoke-test": "bash scripts/smoke-test.sh"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
